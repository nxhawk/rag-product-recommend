# Most runtime config lives in configs/settings.yaml; this file covers
# secrets and Docker-only overrides.

GEMINI_API_KEY=your-key-here

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_products
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
GRPC_PORT=50052
HTTP_PORT=8000

# Service discovery. Leave REGISTRY_URL unset to run standalone (e.g. local
# dev). SERVICE_HOST is what other services should dial - the docker-compose
# service name in that environment.
#
# The values below are the DOCKER ones. `service-registry` and `rag-recommend`
# are compose DNS names - they only resolve inside the compose network.
# Running natively on your host, switch to:
#
#   REGISTRY_URL=http://localhost:8500   (or empty = skip registration)
#   SERVICE_HOST=localhost
#
# SERVICE_HOST is what this instance advertises: the registry probes
# http://$SERVICE_HOST:$HTTP_PORT/health, so it must be reachable *from the
# registry*, not from here. Leaving it as `rag-recommend` while running
# natively means the probe fails and this instance never turns healthy.
# (GRPC_PORT, not HTTP_PORT, is what gets registered as the dialable addr -
# HTTP_PORT only builds the health URL, so keep it in sync with uvicorn's
# --port.) Full local setup: docs/guide/service-registry.md ("Running locally").
REGISTRY_URL=http://service-registry:8500
SERVICE_NAME=rag-recommend
SERVICE_HOST=rag-recommend
